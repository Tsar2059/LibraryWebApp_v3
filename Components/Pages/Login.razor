@page "/login"
@using LibraryWebApp.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="container mt-5" style="max-width: 400px;">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white text-center">
            <h4 class="mb-0">🔐 Вход в админ-панель</h4>
        </div>
        <div class="card-body">
            @if (showError)
            {
                <div class="alert alert-danger">
                    ❌ Неверные учётные данные
                </div>
            }

            <div class="mb-3">
                <label class="form-label">👤 Имя пользователя</label>
                <input type="text" @bind="username" class="form-control" placeholder="Введите логин" />
            </div>

            <div class="mb-3">
                <label class="form-label">🔒 Пароль</label>
                <input type="password" @bind="password" class="form-control" placeholder="Введите пароль" />
            </div>

            <button type="button" class="btn btn-primary w-100" @onclick="HandleLogin" disabled="@isLoading">
                @if (isLoading)
                {
                    <span>⏳ Проверка...</span>
                }
                else
                {
                    <span>🔓 Войти</span>
                }
            </button>
        </div>
        <div class="card-footer text-muted text-center small">
            Только для авторизованных сотрудников
        </div>
    </div>
</div>

<style>
    input {
        transition: all 0.2s ease;
    }
    input:focus {
        transform: scale(1.02);
        box-shadow: 0 0 5px rgba(46,125,50,0.5);
    }
</style>

@code {
    private string username = "";
    private string password = "";
    private bool showError = false;
    private bool isLoading = false;

    private async Task HandleLogin()
    {
        isLoading = true;
        showError = false;
        StateHasChanged();

        // Защита от перебора (искусственная задержка)
        await Task.Delay(800);

        if (AuthService.Login(username, password))
        {
            Navigation.NavigateTo("/admin");
        }
        else
        {
            showError = true;
            isLoading = false;
            StateHasChanged();

            // Очищаем пароль после неудачной попытки
            password = "";
            
            await Task.Delay(3000);
            showError = false;
            StateHasChanged();
        }
    }
}